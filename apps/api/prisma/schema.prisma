generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LaptopStatus {
  AVAILABLE
  RESERVED
  IN_USE
  IN_CONTROL
  DEFECT
  OUT_OF_SERVICE
  MISSING
}

enum UserRole {
  OWNER
  ADMIN
  HELPDESK
}

enum ReservationStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum SoftwareRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
}

model User {
  id                String            @id @default(uuid())
  name              String
  username          String            @unique
  email             String?           @unique
  password          String            @default("asha2024")
  avatar            String?
  role              UserRole
  reservations      Reservation[]     @relation("requester")
  approvals         Reservation[]     @relation("approver")
  reportedIssues    Issue[]           @relation("IssueReporter")
  resolvedIssues    Issue[]           @relation("IssueResolver")
  checklistReports  ChecklistReport[] @relation("ChecklistSubmitter")
  decommissions     DecommissionLog[] @relation("DecommissionUser")
  softwareRequests  SoftwareRequest[] @relation("SoftwareRequester")
  softwareApprovals SoftwareRequest[] @relation("SoftwareApprover")
  notifications     Notification[]
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  userId    String?
  details   String   @default("{}")
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Laptop {
  id                  String            @id @default(uuid())
  status              LaptopStatus      @default(AVAILABLE)
  merk_type           String
  specificaties       String?
  heeft_vga           Boolean           @default(false)
  heeft_hdmi          Boolean           @default(false)
  ram_gb              Int?
  heeft_wifi          Boolean           @default(false)
  wifi_verbonden      Boolean           @default(false)
  alle_toetsen_werken Boolean           @default(false)
  camera_werkt        Boolean           @default(false)
  microfoon_werkt     Boolean           @default(false)
  missingAt           DateTime?
  reservations        Reservation[]     @relation("ReservationLaptops")
  issues              Issue[]
  checklists          ChecklistReport[]
  decommission        DecommissionLog?
  drives              Drive[]
}

model Drive {
  id       String @id @default(uuid())
  laptop   Laptop @relation(fields: [laptopId], references: [id])
  laptopId String
  letter   String
  type     String
  size_gb  Int
  free_gb  Int
}

model Activity {
  id                     String            @id @default(uuid())
  title                  String
  start_datum_tijd       DateTime?
  eind_datum_tijd        DateTime?
  omschrijving           String?
  locatie                String?
  software_benodigdheden String?
  reservations           Reservation[]
  softwareRequests       SoftwareRequest[]
}

model Reservation {
  id              String            @id @default(uuid())
  status          ReservationStatus @default(REQUESTED)
  startDate       DateTime
  endDate         DateTime
  rejectionReason String?
  aanvraag_datum  DateTime          @default(now())
  aantalLaptops   Int               @default(1)
  doel            String            @default("")
  contact_info    String            @default("")
  extra_info      String?
  locatie         String?
  requester       User              @relation("requester", fields: [requesterId], references: [id])
  requesterId     String
  approver        User?             @relation("approver", fields: [approverId], references: [id])
  approverId      String?
  activity        Activity          @relation(fields: [activityId], references: [id])
  activityId      String
  laptops         Laptop[]          @relation("ReservationLaptops")
}

model Issue {
  id           String    @id @default(uuid())
  laptop       Laptop    @relation(fields: [laptopId], references: [id])
  laptopId     String
  reportedBy   User      @relation("IssueReporter", fields: [reportedById], references: [id])
  reportedById String
  description  String
  resolvedBy   User?     @relation("IssueResolver", fields: [resolvedById], references: [id])
  resolvedById String?
  solution     String?
  resolved     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
}

model ChecklistReport {
  id                String   @id @default(uuid())
  laptop            Laptop   @relation(fields: [laptopId], references: [id])
  laptopId          String
  submittedBy       User     @relation("ChecklistSubmitter", fields: [submittedById], references: [id])
  submittedById     String
  geenSchade        Boolean  @default(false)
  geenBestanden     Boolean  @default(false)
  schoongemaakt     Boolean  @default(false)
  accuOk            Boolean  @default(false)
  updatesOk         Boolean  @default(false)
  schijf_type       String?
  schijf_grootte    String?
  schijf_sneller    String?
  ram_totaal        String?
  ram_gebruikt      String?
  opslag_vrij       String?
  opstartprogrammas String?
  energie_ingesteld Boolean?
  wifi_signaal      Int?
  ping_ms           Int?
  toetsenbord_ok    Boolean?
  camera_ok         Boolean?
  microfoon_ok      Boolean?
  passed            Boolean
  createdAt         DateTime @default(now())
}

model DecommissionLog {
  id       String   @id @default(uuid())
  laptop   Laptop   @relation(fields: [laptopId], references: [id])
  laptopId String   @unique
  doneBy   User     @relation("DecommissionUser", fields: [doneById], references: [id])
  doneById String
  reden    String
  datum    DateTime @default(now())
}

model SoftwareRequest {
  id              String                @id @default(uuid())
  title           String
  beschrijving    String?
  status          SoftwareRequestStatus @default(REQUESTED)
  requester       User                  @relation("SoftwareRequester", fields: [requesterId], references: [id])
  requesterId     String
  approver        User?                 @relation("SoftwareApprover", fields: [approverId], references: [id])
  approverId      String?
  activity        Activity              @relation(fields: [activityId], references: [id])
  activityId      String
  rejectionReason String?
  createdAt       DateTime              @default(now())
}
